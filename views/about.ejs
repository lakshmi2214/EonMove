<%- include('partials/header') %>

    <main>
        <!-- About Banner Section -->
        <section class="page-banner"
            style="background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2070&auto=format&fit=crop'); height: 400px; background-position: center; background-size: cover; position: relative; display: flex; align-items: center; justify-content: center;">
            <div class="page-banner-content" style="position: relative; z-index: 2; text-align: center;">
                <h1 style="color: white; font-size: 3.5rem; font-weight: 800; text-shadow: 0 4px 10px rgba(0,0,0,0.3);">
                    About EonMov</h1>
            </div>
            <div
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 1;">
            </div>
        </section>



        <style>
            /* Clients Section */
            .clients-section {
                padding: 3rem 0;
                background: #f8fafc;
                overflow: hidden;
                border-bottom: 1px solid #e2e8f0;
            }

            .clients-heading {
                font-size: 1.2rem;
                font-weight: 700;
                color: #64748b;
                text-transform: uppercase;
                letter-spacing: 2px;
            }

            /* Marquee */
            .marquee-wrapper {
                position: relative;
                width: 100%;
                overflow: hidden;
            }

            .marquee-content {
                display: flex;
                gap: 3rem;
                animation: clientScroll 18s linear infinite;
                width: max-content;
            }

            .marquee-content:hover {
                animation-play-state: paused;
            }

            @keyframes clientScroll {
                0% {
                    transform: translateX(0);
                }

                100% {
                    transform: translateX(-50%);
                }
            }

            /* Client Card with animated border */
            .client-card {
                position: relative;
                min-width: 200px;
                height: 110px;
                border-radius: 16px;
                padding: 3px;
                overflow: hidden;
                flex-shrink: 0;
            }

            /* Spinning gradient border */
            .client-card-border {
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: conic-gradient(#9bcf5a,
                        #29abe2,
                        #00874e,
                        #40b8ea,
                        #9bcf5a);
                animation: spinBorder 3s linear infinite;
                z-index: 0;
            }

            @keyframes spinBorder {
                0% {
                    transform: rotate(0deg);
                }

                100% {
                    transform: rotate(360deg);
                }
            }

            /* Inner card — transparent so logo colors show */
            .client-card-inner {
                position: relative;
                z-index: 1;
                background: #ffffff;
                border-radius: 13px;
                width: 100%;
                height: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1rem 1.5rem;
            }

            .client-card-inner img {
                max-width: 140px;
                max-height: 65px;
                object-fit: contain;
                filter: none;
                transition: transform 0.3s ease;
            }

            .client-card:hover .client-card-inner img {
                transform: scale(1.08);
            }

            .client-placeholder {
                font-weight: 700;
                color: #94a3b8;
                font-size: 0.95rem;
            }

            /* Mobile */
            @media (max-width: 768px) {
                .client-card {
                    min-width: 160px;
                    height: 90px;
                }

                .marquee-content {
                    gap: 2rem;
                }

                .client-card-inner img {
                    max-width: 110px;
                    max-height: 55px;
                }
            }
        </style>

        <!-- Section: Vision & Mission -->
        <section style="padding: 6rem 0; border-bottom: 1px solid #e2e8f0;">
            <div class="container">
                <div style="text-align: center; margin-bottom: 4rem;">
                    <h2 style="font-size: 2.8rem; font-weight: 800; color: #1e293b;">Our Purpose</h2>
                    <div style="height: 4px; width: 60px; background: #9bcf5a; margin: 20px auto; border-radius: 10px;">
                    </div>
                </div>

                <div style="max-width: 900px; margin: 0 auto;">
                    <div class="row g-4 justify-content-center">
                        <!-- Vision Card -->
                        <div class="col-md-6">
                            <div class="vm-card vm-vision">
                                <div class="vm-border-decor"></div>
                                <div class="vm-icon-circle">
                                    <i data-lucide="eye" style="color: #29abe2; width: 22px; height: 22px;"></i>
                                </div>
                                <h3 class="vm-heading">Our Vision</h3>
                                <p class="vm-text">
                                    To lead the global transition to sustainable urban logistics by becoming the most
                                    reliable and green EV ecosystem provider in India.
                                </p>
                            </div>
                        </div>

                        <!-- Mission Card -->
                        <div class="col-md-6">
                            <div class="vm-card vm-mission">
                                <div class="vm-border-decor"></div>
                                <div class="vm-icon-circle">
                                    <i data-lucide="target" style="color: #9bcf5a; width: 22px; height: 22px;"></i>
                                </div>
                                <h3 class="vm-heading">Our Mission</h3>
                                <p class="vm-text">
                                    To provide seamless, tech-enabled, and zero-emission logistics solutions that
                                    empower businesses to grow while protecting our environment.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <style>
            /* Vision & Mission Cards */
            .vm-card {
                padding: 2.5rem 2rem;
                border-radius: 25px;
                height: 100%;
                color: white;
                position: relative;
                overflow: hidden;
                transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                    box-shadow 0.4s ease;
                cursor: default;
            }

            .vm-vision {
                background: linear-gradient(135deg, #29abe2, #2196c9);
                border: 3px solid rgba(255, 255, 255, 0.35);
                box-shadow: 0 12px 30px rgba(41, 171, 226, 0.2);
            }

            .vm-mission {
                background: linear-gradient(135deg, #9bcf5a, #7cb842);
                border: 3px solid rgba(255, 255, 255, 0.35);
                box-shadow: 0 12px 30px rgba(155, 207, 90, 0.2);
            }

            /* Decorative inner dashed border */
            .vm-border-decor {
                position: absolute;
                top: 10px;
                left: 10px;
                right: 10px;
                bottom: 10px;
                border: 2px dashed rgba(255, 255, 255, 0.25);
                border-radius: 18px;
                pointer-events: none;
                transition: border-color 0.4s ease, transform 0.4s ease;
            }

            /* Hover effects */
            .vm-card:hover {
                transform: translateY(-10px) scale(1.03);
            }

            .vm-vision:hover {
                box-shadow: 0 20px 50px rgba(41, 171, 226, 0.35),
                    0 0 20px rgba(41, 171, 226, 0.15);
            }

            .vm-mission:hover {
                box-shadow: 0 20px 50px rgba(155, 207, 90, 0.35),
                    0 0 20px rgba(155, 207, 90, 0.15);
            }

            .vm-card:hover .vm-border-decor {
                border-color: rgba(255, 255, 255, 0.5);
                transform: scale(0.98);
            }

            /* Icon circle */
            .vm-icon-circle {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 55px;
                height: 55px;
                background: white;
                border-radius: 50%;
                margin-bottom: 1.5rem;
                box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
                transition: transform 0.4s ease, box-shadow 0.4s ease;
            }

            .vm-card:hover .vm-icon-circle {
                transform: scale(1.1) rotate(5deg);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }

            /* Heading */
            .vm-heading {
                font-size: 1.8rem;
                font-weight: 800;
                margin-bottom: 1rem;
                color: white;
            }

            /* Text */
            .vm-text {
                font-size: 1rem;
                line-height: 1.7;
                color: rgba(255, 255, 255, 0.92);
                margin-bottom: 0;
            }

            /* Mobile */
            @media (max-width: 768px) {
                .vm-card {
                    padding: 2rem 1.5rem;
                }

                .vm-heading {
                    font-size: 1.5rem;
                }
            }
        </style>

