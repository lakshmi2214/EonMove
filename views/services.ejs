<%- include('partials/header') %>

    <!-- Services Banner -->
    <section class="page-banner"
        style="background-image: url('https://images.unsplash.com/photo-1553413077-190dd305871c?q=80&w=2070&auto=format&fit=crop');">
        <div class="page-banner-content">
            <h1 style="color: white; font-size: 3rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">Our Services</h1>
        </div>
    </section>

    <main>
        <section class="section" style="padding: 6rem 0; background: #ffffff;">
            <div class="container">
                <div style="text-align: center; margin-bottom: 4rem;">
                    <h2 style="font-size: 3rem; font-weight: 950; color: #1e293b;">Our Core Services</h2>
                    <p style="color: #64748b; font-size: 1.2rem; font-weight: 500;">Sustainable and efficient logistics
                        solutions for every scale.</p>
                </div>

                <div style="position: relative; padding: 4rem 2rem;">
                    <!-- Decorative Side Borders -->
                    <div
                        style="position: absolute; top: 0; left: 0; bottom: 0; width: 4px; background: linear-gradient(to bottom, transparent, #9bcf5a, #29abe2, transparent); border-radius: 10px;">
                    </div>
                    <div
                        style="position: absolute; top: 0; right: 0; bottom: 0; width: 4px; background: linear-gradient(to bottom, transparent, #29abe2, #9bcf5a, transparent); border-radius: 10px;">
                    </div>

                    <!-- Top/Bottom Corner Accents -->
                    <div
                        style="position: absolute; top: 0; left: 0; width: 30px; height: 30px; border-top: 4px solid #9bcf5a; border-left: 4px solid #9bcf5a; border-radius: 4px 0 0 0;">
                    </div>
                    <div
                        style="position: absolute; top: 0; right: 0; width: 30px; height: 30px; border-top: 4px solid #29abe2; border-right: 4px solid #29abe2; border-radius: 0 4px 0 0;">
                    </div>
                    <div
                        style="position: absolute; bottom: 0; left: 0; width: 30px; height: 30px; border-bottom: 4px solid #29abe2; border-left: 4px solid #29abe2; border-radius: 0 0 0 4px;">
                    </div>
                    <div
                        style="position: absolute; bottom: 0; right: 0; width: 30px; height: 30px; border-bottom: 4px solid #9bcf5a; border-right: 4px solid #9bcf5a; border-radius: 0 0 4px 0;">
                    </div>

                    <div class="row g-5 align-items-center">
                        <!-- Service 01 -->
                        <div class="col-lg-3 col-md-6 border-end-md" style="border-right: 1px dashed #e2e8f0;">
                            <div
                                style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem; text-align: center;">
                                <div
                                    style="width: 80px; height: 80px; background: #ffffff; border: 3px solid #9bcf5a; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1e293b; font-weight: 900; font-size: 1.8rem; box-shadow: 0 10px 20px rgba(155, 207, 90, 0.15);">
                                    01
                                </div>
                                <div style="color: #1e293b; font-size: 1.25rem; font-weight: 800; line-height: 1.2;">
                                    Primary <br>Logistics
                                </div>
                            </div>
                        </div>
                        <!-- Service 02 -->
                        <div class="col-lg-3 col-md-6" style="border-right: 1px dashed #e2e8f0;">
                            <div
                                style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem; text-align: center;">
                                <div
                                    style="width: 80px; height: 80px; background: #ffffff; border: 3px solid #29abe2; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1e293b; font-weight: 900; font-size: 1.8rem; box-shadow: 0 10px 20px rgba(41, 171, 226, 0.15);">
                                    02
                                </div>
                                <div style="color: #1e293b; font-size: 1.25rem; font-weight: 800; line-height: 1.2;">
                                    Secondary <br>Distribution
                                </div>
                            </div>
                        </div>
                        <!-- Service 03 -->
                        <div class="col-lg-3 col-md-6" style="border-right: 1px dashed #e2e8f0;">
                            <div
                                style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem; text-align: center;">
                                <div
                                    style="width: 80px; height: 80px; background: #ffffff; border: 3px solid #9bcf5a; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1e293b; font-weight: 900; font-size: 1.8rem; box-shadow: 0 10px 20px rgba(155, 207, 90, 0.15);">
                                    03
                                </div>
                                <div style="color: #1e293b; font-size: 1.25rem; font-weight: 800; line-height: 1.2;">
                                    Enterprise <br>Fleet
                                </div>
                            </div>
                        </div>
                        <!-- Service 04 -->
                        <div class="col-lg-3 col-md-6">
                            <div
                                style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem; text-align: center;">
                                <div
                                    style="width: 80px; height: 80px; background: #ffffff; border: 3px solid #29abe2; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1e293b; font-weight: 900; font-size: 1.8rem; box-shadow: 0 10px 20px rgba(41, 171, 226, 0.15);">
                                    04
                                </div>
                                <div style="color: #1e293b; font-size: 1.25rem; font-weight: 800; line-height: 1.2;">
                                    Smart EV <br>Analytics
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Section: 3 Simple Steps to Ship With Us (Premium Dark Branding) -->
        <section
            style="background: #9dc5d6; padding: 6rem 0; position: relative; overflow: hidden; font-family: 'Inter', sans-serif;">
            <div class="container">
                <!-- Heading -->
                <div style="text-align: center; margin-bottom: 5rem;">
                    <h2 style="font-size: 3.2rem; font-weight: 950; color: #ffffff; letter-spacing: -1px;">
                        3 Simple Steps to <span style="color: #29abe2;">Ship With Us</span>
                    </h2>
                </div>

                <div style="position: relative; margin-bottom: 4rem;">
                    <!-- Small Truck Image sitting on the line -->
                    <div style="position: absolute; top: -65px; left: 15px; z-index: 2;">
                        <img src="/images/16469.png" alt="Shipping Truck"
                            style="width: 280px; height: 80px; object-fit: cover; border-radius: 12px; filter: drop-shadow(0 15px 30px rgba(255,255,255,0.05));">
                    </div>

                    <!-- Horizontal Divider Line -->
                    <div style="height: 1px; background: rgba(255,255,255,0.15); width: 100%; margin-bottom: 3.5rem;">
                    </div>

                    <div class="row g-5">
                        <!-- Step 01 -->
                        <div class="col-lg-4">
                            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                <div style="display: flex; align-items: center; gap: 1.25rem;">
                                    <div
                                        style="width: 55px; height: 55px; border-radius: 50%; background: #9bcf5a; color: #ffffff; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.15rem; flex-shrink: 0; box-shadow: 0 10px 20px rgba(155, 207, 90, 0.25);">
                                        01
                                    </div>
                                    <h4
                                        style="color: #ffffff; font-weight: 800; font-size: 1.25rem; margin: 0; line-height: 1.2;">
                                        Contact Our <br>Professional Team</h4>
                                </div>
                                <p
                                    style="color: #94a3b8; font-size: 0.95rem; line-height: 1.7; padding-left: 0.5rem; margin: 0;">
                                    Reach out to us with your shipment details — our dispatch and logistics specialists
                                    will respond quickly.
                                </p>
                            </div>
                        </div>

                        <!-- Step 02 -->
                        <div class="col-lg-4">
                            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                <div style="display: flex; align-items: center; gap: 1.25rem;">
                                    <div
                                        style="width: 55px; height: 55px; border-radius: 50%; background: #29abe2; color: #ffffff; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.15rem; flex-shrink: 0; box-shadow: 0 10px 20px rgba(41, 171, 226, 0.25);">
                                        02
                                    </div>
                                    <h4
                                        style="color: #ffffff; font-weight: 800; font-size: 1.25rem; margin: 0; line-height: 1.2;">
                                        Confirm Your <br>Load & Schedule</h4>
                                </div>
                                <p
                                    style="color: #94a3b8; font-size: 0.95rem; line-height: 1.7; padding-left: 0.5rem; margin: 0;">
                                    We review your freight requirements, discuss the rate, and secure your spot as per
                                    timeline.
                                </p>
                            </div>
                        </div>

                        <!-- Step 03 -->
                        <div class="col-lg-4">
                            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                <div style="display: flex; align-items: center; gap: 1.25rem;">
                                    <div
                                        style="width: 55px; height: 55px; border-radius: 50%; background: #9bcf5a; color: #ffffff; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.15rem; flex-shrink: 0; box-shadow: 0 10px 20px rgba(155, 207, 90, 0.25);">
                                        03
                                    </div>
                                    <h4
                                        style="color: #ffffff; font-weight: 800; font-size: 1.25rem; margin: 0; line-height: 1.2;">
                                        Enjoy Fast, <br>On-Time Delivery</h4>
                                </div>
                                <p
                                    style="color: #94a3b8; font-size: 0.95rem; line-height: 1.7; padding-left: 0.5rem; margin: 0;">
                                    Your freight is transported safely, efficiently, and without delays — with updates
                                    along the way.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Buttons -->
                <div style="margin-top: 5rem; display: flex; align-items: center; gap: 2.5rem;">
                    <a href="/contact"
                        style="background: #9bcf5a; color: #ffffff; padding: 1.1rem 3rem; border-radius: 10px; font-weight: 800; text-decoration: none; font-size: 1rem; box-shadow: 0 15px 30px rgba(155, 207, 90, 0.2); transition: all 0.3s ease;">
                        Get a Quote
                    </a>
                    <a href="/contact"
                        style="color: #ffffff; font-weight: 700; text-decoration: none; font-size: 1rem; display: flex; align-items: center; gap: 0.8rem; transition: color 0.3s ease;">
                        Apply Now <i data-lucide="chevron-right" size="20"></i>
                    </a>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>